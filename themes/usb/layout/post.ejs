<article class="post-article">
  <header class="post-header">
    <h1 class="post-title"><%- page.title %></h1>
    <div class="post-meta">
      <time class="post-date"><%- page.date.format('YYYY-MM-DD') %></time>
      <% if (page.tags && page.tags.length > 0) { %>
      <div class="post-tags">
        <% page.tags.each(function(tag) { %>
          <a href="<%- url_for(tag.path) %>" class="tag-link"><span><%- tag.name %></span></a>
        <% }); %>
      </div>
      <% } %>
    </div>
  </header>
  <div class="post-content">
    <%- page.content %>
  </div>
</article>
