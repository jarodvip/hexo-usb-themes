<div class="archive-page">
  <div class="page-header">
    <h1 class="page-title">归档</h1>
  </div>

  <div class="archive-list">
    <% page.posts.each(function(post) { %>
    <article class="archive-item">
      <time class="archive-date" datetime="<%= post.date.format('YYYY-MM-DD') %>">
        <%= post.date.format('MMMM DD, YYYY') %>
      </time>
      <div class="archive-content">
        <a href="<%- url_for(post.path) %>" class="archive-link">
          <%- post.title %>
        </a>
      </div>
    </article>
    <% }); %>
  </div>
</div>

<% if (page.total > 1) { %>
<nav class="pagination">
  <% if (page.current > 1) { %>
    <a href="<%- url_for(page.prev === 1 ? 'archives/' : 'archives/page/' + page.prev + '/') %>" class="page-link page-prev">
      上一页
    </a>
  <% } %>

  <% for (var i = 1; i <= page.total; i++) { %>
    <% if (i === page.current) { %>
      <span class="page-number current"><%= i %></span>
    <% } else { %>
      <a href="<%- url_for(i === 1 ? 'archives/' : 'archives/page/' + i + '/') %>" class="page-number">
        <%= i %>
      </a>
    <% } %>
  <% } %>

  <% if (page.current < page.total) { %>
    <a href="<%- url_for('archives/page/' + page.next + '/') %>" class="page-link page-next">
      下一页
    </a>
  <% } %>
</nav>
<% } %>
